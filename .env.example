# App password — locks all routes when set (leave unset to disable in local dev)
APP_PASSWORD=your-app-password

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use either name — Supabase dashboard may show "publishable" or "anon"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side (recommended for API routes) — Supabase → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cron security (set in Vercel dashboard)
CRON_SECRET=your-random-secret

# Apify (optional — for LinkedIn, StepStone, GermanTechJobs, Wellfound, Indeed, XING)
APIFY_TOKEN=your-apify-token

# Gemini (future — resume & cover letter generation)
GEMINI_API_KEY=your-gemini-api-key
